# App
APP_PORT=8888
GRPC_PORT=50051
IM_DB_DRIVER=mysql
IM_DB_DSN=root:psword@tcp(mysql:3306)/goim?charset=utf8mb4&parseTime=True&loc=Local

# MQ
IM_MQ_MODE=dual
IM_REDIS_ADDR=redis:6379
IM_REDIS_LIST_KEY=im:deliver:q
IM_KAFKA_BROKERS=kafka:9092
IM_KAFKA_TOPIC=im-deliver
IM_KAFKA_GROUP_ID=im-gate

# Security / Rate limit
IM_BLACKLIST_IPS=
IM_CONN_RATE_WINDOW_SEC=60
IM_CONN_RATE_LIMIT=30

# Delivery retry
IM_DELIVER_MAX_RETRY=5
IM_DELIVER_RETRY_BASE_SEC=2

# Middleware ports
REDIS_PORT=6379
ZOOKEEPER_PORT=2181
KAFKA_PORT=9092
